<?xml version="1.0" encoding="utf-8"?>
<!-- GENERATED by `idealyst run android` in AAS mode. -->
<!-- Permissions: INTERNET + ACCESS_NETWORK_STATE for the WebSocket -->
<!-- connection; CHANGE_WIFI_MULTICAST_STATE so MainActivity can -->
<!-- acquire a MulticastLock around the mDNS browse (Android's Wi-Fi -->
<!-- filter drops multicast otherwise and discovery never finds the -->
<!-- dev-host). -->
<!-- The IdealystAppId meta-data entry mirrors the iOS Info.plist key -->
<!-- and tells the Rust shell which Bonjour TXT record to match on. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="{{PACKAGE}}">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <application
        android:label="{{APP_NAME}}"
        android:hasCode="true">
        <meta-data android:name="IdealystAppId" android:value="{{APP_ID}}" />
        <!-- Optional URL override. Empty string means "discover via Bonjour"; -->
        <!-- the CLI fills this with `ws://127.0.0.1:<port>` for emulator builds -->
        <!-- after setting up `adb reverse tcp:<port> tcp:<port>` to forward the -->
        <!-- host's dev-server port into the emulator's loopback. -->
        <meta-data android:name="IdealystAasUrl" android:value="{{AAS_URL}}" />
        <!-- `configChanges` keeps the Activity alive across rotation,
             multi-window resize, keyboard show/hide, dark-mode toggle,
             density change, etc. Without it Android tears the Activity
             down and recreates it, which restarts the AAS shell and
             the framework mount. The framework reacts to these events
             by re-running its layout pass; see `onConfigurationChanged`
             in MainActivity. -->
        <activity android:name="{{PACKAGE}}.MainActivity"
                  android:exported="true"
                  android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|uiMode|density|navigation|fontScale|layoutDirection"
                  android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
