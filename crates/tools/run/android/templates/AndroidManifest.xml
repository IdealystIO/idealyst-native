<?xml version="1.0" encoding="utf-8"?>
<!-- GENERATED by `idealyst run android`. Minimal manifest declaring
     one launchable Activity. No permissions; no icon resource (the
     OS will use a default), no string resources (label is inline).
     `uses-sdk` versions come from aapt2 link flags, not this file. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="{{PACKAGE}}">
    <application
        android:label="{{APP_NAME}}"
        android:hasCode="true">
        <!-- `configChanges` keeps the Activity alive across rotation,
             multi-window resize, keyboard show/hide, dark-mode toggle,
             density change, etc. Without it Android tears the Activity
             down and recreates it, which restarts the framework mount
             (animations replay, signal state is lost) and computes
             layout for the wrong viewport. The framework reacts to
             these events by re-running its layout pass; see
             `onConfigurationChanged` in MainActivity. -->
        <activity android:name="{{PACKAGE}}.MainActivity"
                  android:exported="true"
                  android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|uiMode|density|navigation|fontScale|layoutDirection"
                  android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
