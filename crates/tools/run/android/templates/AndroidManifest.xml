<?xml version="1.0" encoding="utf-8"?>
<!-- GENERATED by `idealyst run android`. Minimal manifest declaring
     one launchable Activity. No permissions; no icon resource (the
     OS will use a default), no string resources (label is inline).
     `uses-sdk` versions come from aapt2 link flags, not this file. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="{{PACKAGE}}">
    <!-- Capability-derived permissions, injected from SDKs declared in
         the dependency graph (`[package.metadata.idealyst].capabilities`). -->
    {{USES_PERMISSIONS}}
    <!-- `usesCleartextTraffic`: Android 9+ blocks plain HTTP by default,
         which stops a dev build from reaching a server-function / `#[sse]`
         host running over `http://` on the developer's machine (the emulator
         reaches the host loopback via `http://10.0.2.2:<port>`). This manifest
         is GENERATED only by `idealyst run android` (the dev/run path) — a
         release build is packaged separately and keeps the secure default —
         so cleartext is enabled for local development only. -->
    <application
        android:label="{{APP_NAME}}"
        android:usesCleartextTraffic="true"
        android:hasCode="true"{{ICON_ATTRS}}>
        <!-- `configChanges` keeps the Activity alive across rotation,
             multi-window resize, keyboard show/hide, dark-mode toggle,
             density change, etc. Without it Android tears the Activity
             down and recreates it, which restarts the framework mount
             (animations replay, signal state is lost) and computes
             layout for the wrong viewport. The framework reacts to
             these events by re-running its layout pass; see
             `onConfigurationChanged` in MainActivity. -->
        <activity android:name="{{PACKAGE}}.MainActivity"
                  android:exported="true"
                  android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|uiMode|density|navigation|fontScale|layoutDirection"
                  android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Robot bridge relay URL, baked by `idealyst dev` (empty otherwise).
             MainActivity reads it and hands it to Rust before `attach` so the
             app dials the host relay (reached via `adb reverse`) instead of
             self-hosting an on-device TCP bridge. -->
        <meta-data android:name="IdealystRobotRelayUrl" android:value="{{ROBOT_RELAY_URL}}" />
        <!-- Capability-derived services (e.g. the screen_capture
             mediaProjection foreground service), injected from SDKs in the
             dependency graph the same way `{{USES_PERMISSIONS}}` is. -->
        {{SERVICES}}
    </application>
</manifest>
