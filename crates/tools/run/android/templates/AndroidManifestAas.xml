<?xml version="1.0" encoding="utf-8"?>
<!-- GENERATED by `idealyst run android` in AAS mode. -->
<!-- Permissions: INTERNET + ACCESS_NETWORK_STATE for the WebSocket -->
<!-- connection. mDNS / multicast no longer used; the CLI bakes the -->
<!-- dev-server URL directly into IdealystRuntimeServerUrl below. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="{{PACKAGE}}">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Capability-derived permissions, injected from SDKs declared in
         the dependency graph (`[package.metadata.idealyst].capabilities`). -->
    {{USES_PERMISSIONS}}
    <application
        android:label="{{APP_NAME}}"
        android:hasCode="true"{{ICON_ATTRS}}>
        <!-- Dev-server URL the runtime-server client connects to. Filled in by -->
        <!-- the CLI at `idealyst dev` time: `ws://127.0.0.1:<port>` via `adb -->
        <!-- reverse` for emulator builds, `ws://<lan-ip>:<port>` for physical -->
        <!-- devices on the same Wi-Fi. The Activity throws on empty / missing. -->
        <meta-data android:name="IdealystRuntimeServerUrl" android:value="{{AAS_URL}}" />
        <!-- `configChanges` keeps the Activity alive across rotation,
             multi-window resize, keyboard show/hide, dark-mode toggle,
             density change, etc. Without it Android tears the Activity
             down and recreates it, which restarts the AAS shell and
             the framework mount. The framework reacts to these events
             by re-running its layout pass; see `onConfigurationChanged`
             in MainActivity. -->
        <activity android:name="{{PACKAGE}}.MainActivity"
                  android:exported="true"
                  android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|uiMode|density|navigation|fontScale|layoutDirection"
                  android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
